// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         String   @default("ANALYST") // ADMIN | ANALYST | VIEWER
  passwordHash String
  lastLogin    DateTime?
  createdAt    DateTime @default(now())

  resolvedResults ReconciliationResult[]

  @@map("users")
}

model Transaction {
  id                   String   @id @default(cuid())
  externalId           String   @unique
  source               String   // UPI_GPAY | UPI_PHONEPE | CARD_VISA | CARD_MC | WALLET_PAYTM | WALLET_AMAZON
  amount               Int      // stored in paise
  currency             String   @default("INR")
  status               String   // SUCCESS | FAILED | PENDING | REFUNDED
  payerRef             String
  payeeRef             String
  timestamp            DateTime
  rawPayload           String   // JSON string (SQLite doesn't support Json type natively)
  reconciliationStatus String   @default("UNPROCESSED") // UNPROCESSED | MATCHED | FLAGGED | IGNORED
  createdAt            DateTime @default(now())

  reconciliationResult ReconciliationResult?

  @@map("transactions")
}

model SalesOrder {
  id               String    @id @default(cuid())
  orderId          String    @unique
  customerId       String
  customerName     String
  amount           Int       // stored in paise
  currency         String    @default("INR")
  paymentExpected  DateTime
  paymentReceivedAt DateTime?
  status           String    // PAID | UNPAID | PARTIAL | OVERPAID
  source           String    // which channel created this order
  createdAt        DateTime  @default(now())

  reconciliationResult ReconciliationResult?

  @@map("sales_orders")
}

model ReconciliationResult {
  id              String    @id @default(cuid())
  transactionId   String?   @unique
  orderId         String?   @unique
  matchType       String    // EXACT | PARTIAL | DUPLICATE | UNMATCHED_PAYMENT | UNMATCHED_ORDER | DELAYED | FUZZY
  confidenceScore Int       // 0-100
  amountDelta     Int       // in paise, can be negative
  timeDelta       Int       // in minutes, can be negative
  resolvedBy      String?
  resolvedAt      DateTime?
  notes           String?
  status          String    @default("AUTO_MATCHED") // AUTO_MATCHED | FLAGGED | MANUALLY_RESOLVED | IGNORED
  createdAt       DateTime  @default(now())

  transaction Transaction? @relation(fields: [transactionId], references: [id])
  order       SalesOrder?  @relation(fields: [orderId], references: [id])
  resolver    User?        @relation(fields: [resolvedBy], references: [id])

  @@map("reconciliation_results")
}

model AppSettings {
  id                   String @id @default("singleton")
  amountTolerancePct   Float  @default(2.0)
  timeWindowHours      Int    @default(2)
  exactMatchWindowMins Int    @default(15)
  confidenceCutoffAuto Int    @default(90)
  confidenceCutoffFlag Int    @default(60)
  staleOrderHours      Int    @default(48)
  emailOnUnmatched     Boolean @default(true)
  dailyDigest          Boolean @default(false)
  unMatchedThreshold   Int    @default(5)
  updatedAt            DateTime @default(now()) @updatedAt

  @@map("app_settings")
}
